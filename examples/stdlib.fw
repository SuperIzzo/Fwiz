# stdlib.fw — Standard library of common functions
# All defined in pure fwiz using conditions and equations.

[abs]
result = x iff x >= 0
result = -x iff x < 0

[sign]
result = 1 iff x > 0
result = 0 iff x = 0
result = -1 iff x < 0

[clamp]
result = lo iff x < lo
result = x iff x >= lo && x <= hi
result = hi iff x > hi

[max]
result = a iff a >= b
result = b iff b > a

[min]
result = a iff a <= b
result = b iff b < a

[step]
result = 0 iff x < 0
result = 1 iff x >= 0
