# stdlib.fw — Standard library of common functions
# All defined in pure fwiz using conditions and equations.

[abs(x) -> result]
= x iff x >= 0
= -x iff x < 0

[sign(x) -> result]
= 1 iff x > 0
= 0 iff x = 0
= -1 iff x < 0

[clamp(x, lo, hi) -> result]
= lo iff x < lo
= x iff x >= lo && x <= hi
= hi iff x > hi

[max(a, b) -> result]
= a iff a >= b
= b iff b > a

[min(a, b) -> result]
= a iff a <= b
= b iff b < a

[step(x) -> result]
= 0 iff x < 0
= 1 iff x >= 0
